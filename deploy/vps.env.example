API_GATEWAY_HOST_BIND=127.0.0.1
API_GATEWAY_HOST_PORT=9030

KEYCLOAK_HOST_BIND=127.0.0.1
KEYCLOAK_HOST_PORT=8181

MAP_SERVICE_HOST_BIND=127.0.0.1
MAP_SERVICE_HOST_PORT=9530

RAG_SERVICE_HOST_BIND=127.0.0.1
RAG_SERVICE_HOST_PORT=5031

DISCORD_BOT_HOST_BIND=127.0.0.1
DISCORD_BOT_HOST_PORT=4030

MYSQL_HOST_BIND=127.0.0.1
MYSQL_HOST_PORT=3370

OFFICE_SERVICE_HOST_BIND=127.0.0.1
OFFICE_SERVICE_HOST_PORT=8084

USER_SERVICE_HOST_BIND=127.0.0.1
USER_SERVICE_HOST_PORT=8087

DOC_SERVICE_HOST_BIND=127.0.0.1
DOC_SERVICE_HOST_PORT=8088

PROJECT_MANAGER_HOST_BIND=127.0.0.1
