# Copy this file to .env on the VPS before running docker compose.
# These host ports were chosen from the free ports checked on srv1275198.

PUBLIC_FRONTEND_URL=https://metahive.astareo.cloud
PUBLIC_API_BASE_URL=https://api-metahive.astareo.cloud
PUBLIC_KEYCLOAK_URL=https://auth-metahive.astareo.cloud
PUBLIC_MAP_WS_URL=https://map-metahive.astareo.cloud/ws
PUBLIC_RAG_BASE_URL=https://rag-metahive.astareo.cloud
PUBLIC_DISCORD_BACKEND_URL=https://discord-metahive.astareo.cloud

KEYCLOAK_ISSUER_URI=https://auth-metahive.astareo.cloud/realms/meta
MAP_CORS_ALLOWED_ORIGINS=https://metahive.astareo.cloud

FRONTEND_HOST_BIND=127.0.0.1
